<Window x:Class="ProiectPOO.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login Biblioteca" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F0F0">
        <StackPanel Margin="30" VerticalAlignment="Center">
            <TextBlock Text="Autentificare" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <TextBlock Text="Username:"/>
            <TextBox x:Name="txtUsername" Margin="0,5,0,15" Height="25" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="Rol:"/>
            <ComboBox x:Name="cmbRol" Margin="0,5,0,20" Height="25">
                <ComboBoxItem Content="bibliotecar" IsSelected="True"/>
                <ComboBoxItem Content="membru"/>
            </ComboBox>
            
            <Button Content="Intră în Aplicație" Click="BtnLogin_Click" Height="35" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>