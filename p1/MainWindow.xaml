<Window x:Class="ProiectPOO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistem Gestiune Biblioteca Final" Height="750" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl x:Name="MainTabs">
            <TabItem Header="Catalog și Căutare">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Caută (Titlu/Autor/Gen):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtSearch" Width="250" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <Button Content="CAUTĂ" Click="BtnCauta_Click" Width="100" Background="#FFEB3B" FontWeight="Bold"/>
                        <Button Content="REFRESH" Click="BtnRefresh_Click" Width="80" Margin="5,0,0,0"/>
                    </StackPanel>
                    <DataGrid x:Name="dgCarti" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Titlu" Binding="{Binding Titlu}" Width="*"/>
                            <DataGridTextColumn Header="Autor" Binding="{Binding Autor}" Width="*"/>
                            <DataGridTextColumn Header="Gen" Binding="{Binding Gen}" Width="100"/>
                            <DataGridTextColumn Header="Disponibil" Binding="{Binding CopiiDisponibile}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem x:Name="tabAdmin" Header="Meniu Bibliotecar">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Background="#F0F0F0" Margin="5">
                        <TextBlock Text="Adaugă Carte" FontWeight="Bold" Margin="10,10,10,5"/>
                        <TextBox x:Name="addTitlu" Margin="10,0,10,5" Tag="Titlu"/>
                        <TextBox x:Name="addAutor" Margin="10,0,10,5" Tag="Autor"/>
                        <TextBox x:Name="addGen" Margin="10,0,10,5" Tag="Gen"/>
                        <TextBox x:Name="addCopii" Text="1" Margin="10,0,10,10"/>
                        <Button Content="SALVEAZĂ CARTE" Click="BtnAdauga_Click" Height="30" Background="#4CAF50" Foreground="White" Margin="10,0,10,15"/>
                        
                        <TextBlock Text="Acțiuni" FontWeight="Bold" Margin="10,0,10,5"/>
                        <Button Content="Notifică Întârziere &amp; Penalizare" Click="BtnNotifica_Click" Height="40" Background="#FF5722" Foreground="White" Margin="10,0,10,5"/>
                        <Button Content="Șterge Carte Selectată" Click="BtnSterge_Click" Height="30" Background="#F44336" Foreground="White" Margin="10,0,10,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Împrumuturi Active:" FontWeight="Bold"/>
                        <DataGrid x:Name="dgToateImprumuturile" Height="200" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5,0,15">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Membru" Binding="{Binding Username}" Width="100"/>
                                <DataGridTextColumn Header="Carte" Binding="{Binding TitluCarte}" Width="*"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataImprumut}" Width="100"/>
                                <DataGridTextColumn Header="Termen" Binding="{Binding DurataZile}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Recenzii Primite:" FontWeight="Bold"/>
                        <DataGrid x:Name="dgRecenziiBibliotecar" Height="200" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Membru" Binding="{Binding Username}" Width="100"/>
                                <DataGridTextColumn Header="Carte" Binding="{Binding TitluCarte}" Width="150"/>
                                <DataGridTextColumn Header="Notă" Binding="{Binding Rating}" Width="50"/>
                                <DataGridTextColumn Header="Comentariu" Binding="{Binding Comentariu}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="tabMembru" Header="Meniu Membru">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Istoricul tău și Împrumuturi" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="dgIstoricPersonal" Height="300" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Carte" Binding="{Binding TitluCarte}" Width="*"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataImprumut}" Width="120"/>
                                <DataGridTextColumn Header="Zile" Binding="{Binding DurataZile}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="PRELUNGEȘTE ÎMPRUMUT (+7 Zile)" Click="BtnPrelungeste_Click" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" Background="#E3F2FD">
                        <TextBlock Text="Acțiuni Împrumut" FontWeight="Bold" FontSize="14" Margin="10,10,10,10"/>
                        <Label Content="Număr zile dorite:" Margin="10,0,10,0"/>
                        <TextBox x:Name="txtZileImprumut" Text="14" Margin="10,0,10,10"/>
                        <Button Content="ÎMPRUMUTĂ CARTEA SELECTATĂ" Click="BtnImprumuta_Click" Height="45" Background="#2196F3" Foreground="White" FontWeight="Bold" Margin="10,0,10,20"/>
                        
                        <Separator Margin="10,0,10,0"/>
                        <TextBlock Text="Lasă un Review" FontWeight="Bold" Margin="10,10,10,5"/>
                        <Slider x:Name="sldRating" Minimum="1" Maximum="5" IsSnapToTickEnabled="True" TickFrequency="1" Margin="10,5"/>
                        <TextBox x:Name="txtComentariu" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="10,5"/>
                        <Button Content="TRIMITE REVIEW" Click="BtnReview_Click" Height="30" Background="#FF9800" Foreground="White" Margin="10,5,10,10"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>